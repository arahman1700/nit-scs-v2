{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "noEmit": true,
    "declaration": false,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"],
  "exclude": [
    "dist",
    "node_modules",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/test-setup.ts",
    "src/test-utils",
    "src/pages/admin/FeaturesShowcasePage.tsx",
    "src/pages/admin/RoiCalculatorPage.tsx",
    "src/pages/dynamic/DynamicDocumentFormPage.tsx",
    "src/pages/dynamic/DynamicDocumentListPage.tsx",
    "src/pages/admin/CustomDataSourcePage.tsx",
    "src/pages/admin/WorkflowTemplatesPage.tsx"
  ]
}
