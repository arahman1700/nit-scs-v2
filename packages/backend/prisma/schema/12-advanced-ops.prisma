// ############################################################################
// SECTION: AI MODULE (3 models — optional, behind AI_ENABLED flag)
// ############################################################################

/// AI chat conversation
model AiConversation {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  title     String?  @db.VarChar(200)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  user     Employee    @relation("AiConvUser", fields: [userId], references: [id], onDelete: Cascade)
  messages AiMessage[]

  @@index([userId], map: "idx_ai_conv_user")
  @@map("FND_AI_CONVERSATIONS")
}

/// AI chat message within a conversation
model AiMessage {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  /// 'user' | 'assistant'
  role           String   @db.VarChar(20)
  content        String
  /// SQL query generated by AI (if applicable)
  generatedQuery String?  @map("generated_query")
  /// Result data from query execution
  resultData     Json?    @map("result_data") @db.JsonB
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId], map: "idx_ai_msg_conv")
  @@map("FND_AI_MESSAGES")
}

/// AI-generated suggestion for system optimization
model AiSuggestion {
  id             String    @id @default(uuid()) @db.Uuid
  /// slow_moving|delay|cost_anomaly|automation|supplier_rating|reorder|sla
  suggestionType String    @map("suggestion_type") @db.VarChar(30)
  /// 1=critical, 2=high, 3=medium, 4=low
  priority       Int       @default(3)
  title          String    @db.VarChar(300)
  description    String?
  /// Action payload for one-click apply: { type, params }
  actionPayload  Json?     @map("action_payload") @db.JsonB
  /// pending|applied|dismissed
  status         String    @default("pending") @db.VarChar(20)
  /// Dedup fingerprint to avoid duplicates
  fingerprint    String    @unique @db.VarChar(200)
  expiresAt      DateTime? @map("expires_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@index([status, priority], map: "idx_ai_suggestions_status")
  @@map("FND_AI_SUGGESTIONS")
}

// ############################################################################
